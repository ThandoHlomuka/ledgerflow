{
  "name": "ledgerflow",
  "version": "1.0.0",
  "description": "LedgerFlow — Intelligent Accounting & Bookkeeping System",
  "author": "Thando Hlomuka",
  "license": "SEE LICENSE IN LICENSE",
  "main": "electron/main.js",
  "scripts": {
    "start": "vercel dev",
    "build": "echo static",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win --mac --linux",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.thandohlomuka.ledgerflow",
    "productName": "LedgerFlow",
    "copyright": "Copyright © 2026 Thando Hlomuka. All rights reserved.",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "api/**/*",
      "electron/**/*",
      "icons/**/*",
      "manifest.json",
      "sw.js",
      "vercel.json",
      "LICENSE"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icons/icon.svg",
      "artifactName": "${productName}-Setup-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "icons/icon.svg",
      "category": "public.app-category.finance",
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icons/icon.svg",
      "category": "Finance",
      "artifactName": "${productName}-${version}-linux.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
